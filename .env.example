# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key — get one at https://dash.voyageai.com/
VOYAGE_API_KEY=pa-...

# TwelveData API key — get one at https://twelvedata.com/
TWELVEDATA_API_KEY=...
# Default model for the agent
AW_DEFAULT_MODEL=claude-sonnet-4-5

# Embedding model for RAG
AW_EMBEDDING_MODEL=voyage-3

# Path to the ChromaDB store
AW_CHROMA_PATH=./data/chroma

# Logging
AW_LOG_LEVEL=INFO